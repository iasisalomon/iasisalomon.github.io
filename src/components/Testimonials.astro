---
import proof from '../data/proof.json';
import partnerBrands from '../data/partnerBrands.json';

const { testimonials } = proof as {
  organizations: string[];
  testimonials: { quote: string; name: string; role: string; org?: string }[];
};

type PartnerBrand = {
  name: string;
  logo: string;
  darkTile?: boolean;
  url?: string;
};

const brands = partnerBrands as PartnerBrand[];
const carouselBrands = [...brands, ...brands];
---

<section id="proof" class="py-6">
  <div class="container">
    <h2 class="text-center mt-1 mb-4">Worked With</h2>
    <div class="section-divider mb-5"></div>

    <div class="brand-carousel" aria-label="Organizations Iasi has worked with">
      <div class="brand-carousel__track">
        {carouselBrands.map((brand, index) => (
          <div
            class:list={[
              'brand-carousel__item',
              { 'brand-carousel__item--dark': brand.darkTile },
            ]}
            aria-hidden={index >= brands.length ? 'true' : undefined}
          >
            {brand.url ? (
              <a
                class="brand-carousel__link"
                href={brand.url}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${brand.name} (opens in a new tab)`}
                tabindex={index >= brands.length ? -1 : undefined}
              >
                <img
                  src={brand.logo}
                  alt={index < brands.length ? `${brand.name} logo` : ''}
                  loading="lazy"
                  decoding="async"
                  width="160"
                  height="64"
                />
              </a>
            ) : (
              <img
                src={brand.logo}
                alt={index < brands.length ? `${brand.name} logo` : ''}
                loading="lazy"
                decoding="async"
                width="160"
                height="64"
              />
            )}
          </div>
        ))}
      </div>
    </div>

    {testimonials.length > 0 && (
      <div class="row g-4 justify-content-center mt-4">
        {testimonials.map((t) => (
          <div class="col-md-6 col-lg-4">
            <figure class="testimonial h-100 p-4 rounded-4 bg-light">
              <blockquote class="mb-3">"{t.quote}"</blockquote>
              <figcaption class="small text-muted">
                <strong class="d-block text-dark">{t.name}</strong>
                {t.role}{t.org ? `, ${t.org}` : ''}
              </figcaption>
            </figure>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .brand-carousel {
    --carousel-gap: 1.25rem;
    --carousel-speed: 42s;
    position: relative;
    overflow: hidden;
    mask-image: linear-gradient(
      to right,
      transparent,
      #000 8%,
      #000 92%,
      transparent
    );
  }

  .brand-carousel__track {
    display: flex;
    align-items: center;
    gap: var(--carousel-gap);
    width: max-content;
    animation: brand-scroll var(--carousel-speed) linear infinite;
  }

  .brand-carousel:hover .brand-carousel__track {
    animation-play-state: paused;
  }

  .brand-carousel__item {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 11rem;
    height: 5rem;
    padding: 0.85rem 1.1rem;
    border-radius: var(--radius-card, 1rem);
    border: 1px solid var(--color-border, rgba(0, 0, 0, 0.08));
    background: #fff;
    box-shadow: 0 0.25rem 0.75rem rgba(0, 0, 0, 0.04);
  }

  .brand-carousel__item--dark {
    background: var(--color-surface-dark, #212529);
    border-color: rgba(255, 255, 255, 0.12);
  }

  .brand-carousel__item img {
    display: block;
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    object-position: center;
  }

  .brand-carousel__link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .brand-carousel__link:hover,
  .brand-carousel__link:focus-visible {
    transform: scale(1.06);
    opacity: 0.85;
  }

  .brand-carousel__link:focus-visible {
    outline: 2px solid var(--color-accent, #4d9aff);
    outline-offset: 4px;
    border-radius: 0.5rem;
  }

  .testimonial {
    border: 1px solid var(--color-border, rgba(0, 0, 0, 0.08));
  }

  .testimonial blockquote {
    font-size: 1.05rem;
    line-height: 1.6;
    font-style: italic;
  }

  @keyframes brand-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(calc(-50% - var(--carousel-gap) / 2));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-carousel {
      mask-image: none;
      overflow-x: auto;
      scrollbar-width: thin;
    }

    .brand-carousel__track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
      width: auto;
      padding-bottom: 0.5rem;
    }

    .brand-carousel__item[aria-hidden='true'] {
      display: none;
    }
  }
</style>
