---
import { featuredProjects } from '../data/portfolio';
import { getCollection } from 'astro:content';
import { AREA_META } from '../data/areas';

// Only feature projects that actually have a written case study.
const studies = await getCollection('caseStudies');
const studyBySlug = new Map(studies.map((e) => [e.slug, e]));

const items = featuredProjects
  .filter((p) => studyBySlug.has(p.slug))
  .map((p) => ({ project: p, area: AREA_META[p.category], study: studyBySlug.get(p.slug)! }));
---

{items.length > 0 && (
  <section id="work" class="py-6">
    <div class="container">
      <div class="d-flex align-items-end justify-content-between mb-4 flex-wrap gap-2">
        <div>
          <h2 class="mb-1">Selected Work</h2>
          <p class="text-muted mb-0">A few projects, told in depth.</p>
        </div>
        <a href="#projects" class="btn btn-sm btn-outline-dark">View all projects <i class="fas fa-arrow-down ms-1"></i></a>
      </div>
      <div class="section-divider mb-4" style="margin-left:0"></div>

      <div class="row g-4">
        {items.map(({ project, area, study }) => (
          <div class="col-md-4">
            <a href={`/projects/${project.slug}`} class="work-card h-100 d-flex flex-column rounded-4 overflow-hidden text-reset">
              <div class={`work-card-top ${area.gradientClass} text-white p-4`}>
                <div class="d-flex justify-content-between align-items-center mb-4">
                  <span class="badge bg-light text-dark">{area.label}</span>
                  <i class={`${area.icon} h4 mb-0 opacity-75`}></i>
                </div>
                <h3 class="h4 fw-bold mb-0">{project.title}</h3>
              </div>
              <div class="work-card-body bg-white p-4 d-flex flex-column flex-grow-1">
                <p class="text-muted small mb-3 flex-grow-1">{study.data.outcome ?? project.description}</p>
                <span class="read-cta fw-medium">Read case study <i class="fas fa-arrow-right ms-1"></i></span>
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .work-card {
    text-decoration: none;
    box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, 0.08);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .work-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.16);
  }

  .read-cta {
    color: var(--color-accent, #0d6efd);
  }

  .read-cta i {
    transition: transform 0.2s ease;
  }

  .work-card:hover .read-cta i {
    transform: translateX(4px);
  }
</style>
