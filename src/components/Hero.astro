---
import { AREA_META } from '../data/areas';
const subtitles = Object.values(AREA_META).map((a) => a.label);
---

<section id="home" class="min-vh-100 d-flex flex-column bg-dark text-white">
  <div class="flex-grow-1 d-flex align-items-center">
    <div class="container text-center">
      <div class="profile-image mb-4">
        <img
          src="/images/cara.jpg"
          alt="Iasi Salomon"
          class="rounded-circle img-fluid shadow-lg"
          width="180"
          height="180"
        />
      </div>
      <h1 class="display-2 mb-2">Iasi Salomon</h1>
      <p class="roles mb-4">
        <span id="heroSubtitle" class="subtitle-text">{subtitles[0]}</span>
      </p>

      <p class="thesis lead mx-auto mb-5">
        I take complex, ambiguous things — fast-growing orgs, raw data, live global events,
        new technical domains — and make them work: <strong>structured, scalable, shipped.</strong>
      </p>

      <div class="hero-ctas mb-5">
        <a href="#work" class="btn btn-light btn-lg me-2 mb-2 cta-primary">
          See my work <i class="fas fa-arrow-down ms-2"></i>
        </a>
        <a href="#discussion" class="btn btn-outline-light btn-lg mb-2 cta-btn">
          Let's talk <i class="fas fa-arrow-right ms-2"></i>
        </a>
      </div>

      <div class="social-links">
        <a href="https://github.com/iasisalomon" class="text-white mx-3 h4" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
          <i class="fab fa-github"></i>
        </a>
        <a href="https://linkedin.com/in/iasisalomon" class="text-white mx-3 h4" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <i class="fab fa-linkedin"></i>
        </a>
        <a href="https://x.com/glunisok" class="text-white mx-3 h4" target="_blank" rel="noopener noreferrer" aria-label="Twitter / X">
          <i class="fab fa-x-twitter"></i>
        </a>
        <a href="https://t.me/oxaciano" class="text-white mx-3 h4" target="_blank" rel="noopener noreferrer" aria-label="Telegram">
          <i class="fab fa-telegram-plane"></i>
        </a>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ subtitles }}>
  const el = document.getElementById('heroSubtitle');
  let index = 0;

  function rotateSubtitle() {
    el.style.opacity = '0';
    setTimeout(() => {
      index = (index + 1) % subtitles.length;
      el.textContent = subtitles[index];
      el.style.opacity = '1';
    }, 400);
  }

  // Respect users who prefer reduced motion — show the first role and stop.
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    setInterval(rotateSubtitle, 3000);
  }
</script>

<style>
  #home {
    padding-top: 76px;
  }

  .profile-image img {
    border: 4px solid rgba(255,255,255,0.2);
    transition: transform 0.3s ease;
  }

  .profile-image img:hover {
    transform: scale(1.05);
  }

  .roles {
    font-size: 1.1rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-accent, #4d9aff);
    font-weight: 600;
  }

  .subtitle-text {
    transition: opacity 0.4s ease;
    display: inline-block;
  }

  .thesis {
    max-width: 60ch;
    font-size: 1.35rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.85);
  }

  .thesis strong {
    color: #fff;
  }

  .cta-primary {
    font-weight: 600;
    transition: all 0.25s ease;
  }

  .cta-primary:hover {
    transform: translateY(-2px);
  }

  .cta-btn {
    border-color: rgba(255,255,255,0.5);
    transition: all 0.25s ease;
  }

  .cta-btn:hover {
    background-color: rgba(255,255,255,0.1);
    border-color: #fff;
    transform: translateY(-2px);
  }

  .social-links {
    margin-top: 1rem;
  }

  .social-links a {
    transition: opacity 0.2s, transform 0.2s;
  }

  .social-links a:hover {
    opacity: 0.8;
    transform: translateY(-3px);
  }

  @media (max-width: 768px) {
    .profile-image img {
      width: 150px;
      height: 150px;
    }

    #home {
      padding-top: 60px;
    }

    .thesis {
      font-size: 1.15rem;
    }

    .social-links a {
      margin-left: 0.75rem !important;
      margin-right: 0.75rem !important;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .profile-image img:hover,
    .cta-primary:hover,
    .cta-btn:hover,
    .social-links a:hover {
      transform: none;
    }
  }
</style>
