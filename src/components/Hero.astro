---
import projectsData from '../data/projects.json';
const { brands } = projectsData;
const subtitles = brands.map(b => b.description);
---

<section id="home" class="min-vh-100 d-flex flex-column bg-dark text-white">
  <div class="flex-grow-1 d-flex align-items-center">
    <div class="container text-center">
      <div class="profile-image mb-4">
        <img
          src="/images/cara.jpg"
          alt="Iasi Salomon"
          class="rounded-circle img-fluid shadow-lg"
          width="180"
          height="180"
        />
      </div>
      <h1 class="display-2 mb-3">Iasi Salomon</h1>
      <p class="lead subtitle mb-5">
        <span id="heroSubtitle" class="subtitle-text">{subtitles[0]}</span>
      </p>
      <div class="mb-5">
        <a href="#projects" class="btn btn-outline-light btn-lg cta-btn">
          View Projects <i class="fas fa-arrow-down ms-2"></i>
        </a>
      </div>
      <div class="social-links">
        <a href="https://github.com/iasisalomon" class="text-white mx-3 h4" target="_blank" rel="noopener noreferrer">
          <i class="fab fa-github"></i>
        </a>
        <a href="https://linkedin.com/in/iasisalomon" class="text-white mx-3 h4" target="_blank" rel="noopener noreferrer">
          <i class="fab fa-linkedin"></i>
        </a>
        <a href="https://x.com/glunisok" class="text-white mx-3 h4" target="_blank" rel="noopener noreferrer">
          <i class="fab fa-x-twitter"></i>
        </a>
        <a href="https://t.me/oxaciano" class="text-white mx-3 h4" target="_blank" rel="noopener noreferrer">
          <i class="fab fa-telegram-plane"></i>
        </a>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ subtitles }}>
  const el = document.getElementById('heroSubtitle');
  let index = 0;

  function rotateSubtitle() {
    el.style.opacity = '0';
    setTimeout(() => {
      index = (index + 1) % subtitles.length;
      el.textContent = subtitles[index];
      el.style.opacity = '1';
    }, 400);
  }

  setInterval(rotateSubtitle, 3000);
</script>

<style>
  #home {
    padding-top: 76px;
  }

  .profile-image img {
    border: 4px solid rgba(255,255,255,0.2);
    transition: transform 0.3s ease;
  }

  .profile-image img:hover {
    transform: scale(1.05);
  }

  .subtitle-text {
    transition: opacity 0.4s ease;
    display: inline-block;
  }

  .cta-btn {
    border-color: rgba(255,255,255,0.5);
    transition: all 0.25s ease;
  }

  .cta-btn:hover {
    background-color: rgba(255,255,255,0.1);
    border-color: #fff;
    transform: translateY(-2px);
  }

  .social-links {
    margin-top: 1rem;
  }

  .social-links a {
    transition: opacity 0.2s, transform 0.2s;
  }

  .social-links a:hover {
    opacity: 0.8;
    transform: translateY(-3px);
  }

  @media (max-width: 768px) {
    .profile-image img {
      width: 150px;
      height: 150px;
    }

    #home {
      padding-top: 60px;
    }

    .social-links a {
      margin-left: 0.75rem !important;
      margin-right: 0.75rem !important;
    }
  }
</style>
