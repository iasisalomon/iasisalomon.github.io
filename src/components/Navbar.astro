---
// Context-aware navbar with two render-time variants:
//  - 'main' (default): in-page section links (`/#id`). On the homepage they
//    smooth-scroll; from any other page they navigate home and the on-load
//    handler scrolls into place. "Blog" points at the homepage's
//    From-the-Blog teaser.
//  - 'blog': the blog is its own space — category links driving the archive
//    filter plus a single "Main site" link back. No homepage section links.
import { BLOG_CATEGORIES } from '../consts';

interface Props {
  variant?: 'main' | 'blog';
  /** Blog variant only: category to mark active at render time (used by
   *  post pages). The archive page manages active state client-side from
   *  the ?category URL param instead. */
  activeCategory?: string;
}
const { variant = 'main', activeCategory } = Astro.props;

const mainLinks = [
  { label: 'About', href: '/#about' },
  { label: 'Expertise', href: '/#expertise' },
  { label: 'Work', href: '/#work' },
  { label: 'Projects', href: '/#projects' },
  { label: 'Contact', href: '/#discussion' },
  { label: 'Blog', href: '/#blog' },
];

const blogLinks = [
  { label: 'All', href: '/blog', category: 'all' },
  ...BLOG_CATEGORIES.map((c) => ({
    label: c.label,
    href: `/blog?category=${c.id}`,
    category: c.id as string,
  })),
];
---

<nav class="navbar navbar-expand-lg navbar-dark fixed-top" id="mainNav">
  <div class="container">
    <a class="navbar-brand" href="/">Iasi Salomon</a>
    <!-- Toggle lives outside the collapse so it stays visible (and usable)
         without opening the menu; order-lg-last places it after the nav
         links on desktop. -->
    <div class="nav-controls d-flex align-items-center gap-2 order-lg-last">
      <button
        type="button"
        class="theme-toggle"
        id="themeToggle"
        aria-label="Switch between dark and light theme"
      >
        <i class="fas fa-moon toggle-icon-dark" aria-hidden="true"></i>
        <i class="fas fa-sun toggle-icon-light" aria-hidden="true"></i>
      </button>
      <button
        class="navbar-toggler"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#navbarNav"
        aria-label="Toggle navigation"
      >
        <span class="navbar-toggler-icon"></span>
      </button>
    </div>
    <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
      <ul class="navbar-nav main-nav">
        {variant === 'main' &&
          mainLinks.map((link) => (
            <li class="nav-item">
              <a class="nav-link" href={link.href}>{link.label}</a>
            </li>
          ))}
        {variant === 'blog' && (
          <>
            {blogLinks.map((link) => (
              <li class="nav-item">
                <a
                  class:list={['nav-link', { active: link.category === activeCategory }]}
                  href={link.href}
                  data-category={link.category}
                >
                  {link.label}
                </a>
              </li>
            ))}
            <li class="nav-item nav-item--return">
              <a class="nav-link" href="/">
                <i class="fas fa-arrow-left me-1" aria-hidden="true"></i>Main site
              </a>
            </li>
          </>
        )}
      </ul>
    </div>
  </div>
</nav>

<style>
  #mainNav {
    background-color: rgba(28, 31, 35, 0.98);
    padding: 0.6rem 0;
    transition: all 0.3s ease;
    z-index: 1030;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  .navbar-brand {
    font-weight: 700;
    letter-spacing: 0.2px;
    color: #fff;
  }

  .main-nav .nav-item {
    margin: 0 0.15rem;
  }

  .main-nav .nav-link {
    padding: 0.5rem 0.9rem;
    font-weight: 500;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.85);
    position: relative;
    letter-spacing: 0.2px;
    transition: color 0.3s ease, background-color 0.3s ease;
    border-radius: 4px;
    background-color: transparent;
  }

  /* Animated underline */
  .main-nav .nav-link::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 10%;
    width: 80%;
    height: 2px;
    background-color: var(--color-accent-on-dark, #4d9aff);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.3s ease;
  }

  .main-nav .nav-link:hover {
    color: #fff;
    background-color: rgba(255, 255, 255, 0.1);
  }

  .main-nav .nav-link.active {
    color: #fff;
  }

  .main-nav .nav-link.active::after {
    transform: scaleX(1);
  }

  .nav-controls {
    margin-left: 0.6rem;
  }

  /* Blog variant: separate the "Main site" return link from the
     category links. */
  .nav-item--return {
    border-left: 1px solid rgba(255, 255, 255, 0.15);
    margin-left: 0.5rem;
    padding-left: 0.5rem;
  }

  .nav-item--return .nav-link {
    color: rgba(255, 255, 255, 0.6);
  }

  .theme-toggle {
    background-color: rgba(255, 255, 255, 0.08);
    border: none;
    border-radius: 100px;
    color: rgba(255, 255, 255, 0.85);
    cursor: pointer;
    font-size: 0.95rem;
    line-height: 1;
    padding: 0.5rem 0.75rem;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .theme-toggle:hover {
    background-color: rgba(255, 255, 255, 0.16);
    color: #fff;
  }

  /* Moon shown in light mode (action: go dark), sun in dark mode. */
  .toggle-icon-light {
    display: none;
  }

  :global([data-theme='dark']) .toggle-icon-light {
    display: inline-block;
  }

  :global([data-theme='dark']) .toggle-icon-dark {
    display: none;
  }

  .navbar-toggler {
    border: none;
    background-color: rgba(255, 255, 255, 0.08);
    padding: 0.4rem 0.6rem;
    font-size: 0.9rem;
    transition: all 0.2s ease;
  }

  .navbar-toggler:hover {
    background-color: rgba(255, 255, 255, 0.15);
  }

  .navbar-toggler:focus {
    box-shadow: none;
  }

  @media (max-width: 991.98px) {
    #mainNav {
      padding: 0.5rem 0;
    }

    /* The navbar has a fixed height, so the expanded menu overflows past
       the navbar's painted background — give the collapse its own solid
       panel or the links float transparently over page content. */
    .navbar-collapse {
      background-color: rgba(28, 31, 35, 0.98);
      border-radius: 0 0 10px 10px;
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
      margin-top: 0.5rem;
      padding: 0.5rem 1rem 0.75rem;
    }

    .navbar-nav {
      padding: 0.5rem 0;
      text-align: center;
      width: 100%;
    }

    .main-nav .nav-item {
      margin: 0;
      width: 100%;
    }

    .main-nav .nav-link {
      padding: 0.6rem 1rem;
      display: block;
    }

    /* Underline replaced by a subtle background highlight on mobile */
    .main-nav .nav-link::after {
      display: none;
    }

    .main-nav .nav-link.active {
      background-color: rgba(255, 255, 255, 0.15);
    }

    /* Collapsed menu: the return link's side divider becomes a top rule. */
    .nav-item--return {
      border-left: none;
      border-top: 1px solid rgba(255, 255, 255, 0.15);
      margin: 0.4rem 0 0;
      padding: 0.4rem 0 0;
    }
  }
</style>

<script>
  // Theme toggle: flips data-theme on <html> and persists the choice.
  // The pre-paint script in MainLayout reads the same localStorage key.
  document.getElementById('themeToggle')?.addEventListener('click', () => {
    const root = document.documentElement;
    const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    if (next === 'dark') {
      root.setAttribute('data-theme', 'dark');
    } else {
      root.removeAttribute('data-theme');
    }
    try {
      localStorage.setItem('theme', next);
    } catch {}
  });

  document.addEventListener('DOMContentLoaded', function () {
    const nav = document.getElementById('mainNav');
    const collapse = document.getElementById('navbarNav');
    const isHome = window.location.pathname === '/' || window.location.pathname === '';

    const anchorLinks = Array.from(
      document.querySelectorAll('#navbarNav .nav-link')
    ).filter((l) => (l.getAttribute('href') || '').includes('#'));

    function hashOf(link) {
      const href = link.getAttribute('href') || '';
      const i = href.indexOf('#');
      return i >= 0 ? href.slice(i) : null; // e.g. '#about'
    }

    // While a click-initiated smooth scroll is in flight the scroll-spy is
    // suppressed, otherwise it re-marks every section passing by and the
    // marker ping-pongs. 200ms without a scroll event = settled (also
    // covers the user interrupting the animation with the wheel).
    let autoScrolling = false;
    let settleTimer = null;

    function suppressSpy() {
      autoScrolling = true;
      clearTimeout(settleTimer);
      settleTimer = setTimeout(function () {
        autoScrolling = false;
      }, 200);
    }

    function scrollToSection(hash) {
      const section = document.querySelector(hash);
      if (!section) return false;
      suppressSpy();
      window.scrollTo({ top: section.offsetTop - nav.offsetHeight - 10, behavior: 'smooth' });
      return true;
    }

    function setActive(hash) {
      anchorLinks.forEach((l) => l.classList.toggle('active', hashOf(l) === hash));
    }

    if (!isHome) return; // On other pages the links are plain navigation.

    // Smooth-scroll for in-page section links.
    anchorLinks.forEach((link) => {
      link.addEventListener('click', function (e) {
        const hash = hashOf(link);
        if (!hash || !document.querySelector(hash)) return; // let it navigate
        e.preventDefault();
        setActive(hash);
        scrollToSection(hash);
        // Close the mobile menu via Bootstrap's API rather than simulating a
        // toggler click — a synthetic click fired mid-transition desyncs
        // Bootstrap's internal state and breaks the next tap on touch devices.
        if (collapse.classList.contains('show') && window.bootstrap) {
          window.bootstrap.Collapse.getOrCreateInstance(collapse).hide();
        }
      });
    });

    // Scroll-spy: highlight the section currently in view.
    let ticking = false;
    window.addEventListener('scroll', function () {
      if (autoScrolling) {
        // Still in flight — keep extending the settle window and leave
        // the marker on the clicked target.
        suppressSpy();
        return;
      }
      if (ticking) return;
      ticking = true;
      setTimeout(function () {
        if (autoScrolling) {
          // A click landed while this callback was queued.
          ticking = false;
          return;
        }
        const scrollPos = window.scrollY + nav.offsetHeight + 20;
        let current = null;
        document.querySelectorAll('section[id]').forEach(function (sec) {
          if (scrollPos >= sec.offsetTop && scrollPos < sec.offsetTop + sec.offsetHeight) {
            current = '#' + sec.id;
          }
        });
        if (
          !current &&
          window.scrollY + window.innerHeight >= document.documentElement.scrollHeight - 5
        ) {
          const last = anchorLinks[anchorLinks.length - 1];
          if (last) current = hashOf(last);
        }
        if (current) setActive(current);
        ticking = false;
      }, 100);
    });

    // Arriving with a hash (e.g. from another page): scroll into place.
    if (window.location.hash) {
      const hash = window.location.hash;
      setTimeout(function () {
        scrollToSection(hash);
        setActive(hash);
      }, 300);
    }
  });
</script>
