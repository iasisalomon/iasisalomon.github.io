---
import { getCollection } from 'astro:content';

// Latest posts as a teaser; the full archive lives at /blog.
const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf())
  .slice(0, 3);

const categoryLabels: Record<string, string> = {
  tech: 'Tech',
  business: 'Business',
  other: 'Other',
};
---

<section id="blog" class="py-6 bg-light">
  <div class="container">
    <div class="d-flex align-items-end justify-content-between mb-4 flex-wrap gap-2">
      <div>
        <h2 class="mb-1">From the Blog</h2>
        <p class="text-muted mb-0">Thoughts on tech, business and the spaces between.</p>
      </div>
      <a href="/blog" class="btn btn-sm btn-outline-dark">View all articles <i class="fas fa-arrow-right ms-1"></i></a>
    </div>
    <div class="section-divider mb-4" style="margin-left:0"></div>

    <div class="row g-4">
      {posts.map((post) => (
        <div class="col-md-6 col-lg-4">
          <a href={`/blog/${post.id}/`} class="writing-card h-100 d-flex flex-column bg-white rounded-4 overflow-hidden text-reset">
            <div class="writing-img">
              <img src={post.data.heroImage || '/images/blog/axie-infinity-land-v1.webp'} alt={post.data.title} loading="lazy" />
            </div>
            <div class="p-4 d-flex flex-column flex-grow-1">
              <div class="d-flex align-items-center gap-2 mb-2 small text-muted">
                {post.data.pubDate && (
                  <time datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString('en-us', { year: 'numeric', month: 'short', day: 'numeric' })}
                  </time>
                )}
                {post.data.category && (
                  <span class="badge bg-light text-dark border">{categoryLabels[post.data.category] ?? post.data.category}</span>
                )}
              </div>
              <h3 class="h5 fw-bold mb-2">{post.data.title}</h3>
              <p class="text-muted small mb-3 flex-grow-1">{post.data.description}</p>
              <span class="read-cta fw-medium small">Read article <i class="fas fa-arrow-right ms-1"></i></span>
            </div>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .writing-card {
    text-decoration: none;
    border: 1px solid var(--color-border, rgba(0, 0, 0, 0.08));
    box-shadow: 0 0.4rem 1.2rem rgba(0, 0, 0, 0.05);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .writing-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 1rem 2.5rem rgba(0, 0, 0, 0.12);
  }

  .writing-img {
    height: 170px;
    overflow: hidden;
  }

  .writing-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .writing-card:hover .writing-img img {
    transform: scale(1.05);
  }

  .read-cta {
    color: var(--color-accent, #0d6efd);
  }

  .read-cta i {
    transition: transform 0.2s ease;
  }

  .writing-card:hover .read-cta i {
    transform: translateX(4px);
  }

  @media (prefers-reduced-motion: reduce) {
    .writing-card:hover { transform: none; }
    .writing-card:hover .writing-img img { transform: none; }
  }
</style>
