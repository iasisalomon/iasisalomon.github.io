---
import aboutData from '../data/about.json';
const { experiences } = aboutData;
---

<section id="about" class="py-6">
  <div class="container">
    <h2 class="text-center mt-1 mb-4">About Me</h2>
    <div class="section-divider mb-5"></div>

    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="about-content">
          <p class="lead mb-5">
            I excel at <strong>driving complex projects</strong> to completion, leading cross-functional teams, and ensuring excellence at every stage. With a background encompassing <em>IT</em>, <em>security</em>, <em>fintech</em>, and <em>operations</em>, I specialize in optimizing workflows, fostering collaboration, and delivering scalable solutions that make an impact.
          </p>

          {experiences.map((exp, i) => (
            <>
              <div class="experience-section mb-5">
                <h3 class="h5 mb-3">
                  <i class={`${exp.icon} me-2 text-primary`}></i>{exp.title}
                </h3>
                <p class="mb-0" set:html={exp.content} />
              </div>
              {i < experiences.length - 1 && <hr class="my-5 text-muted" />}
            </>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-content {
    color: var(--color-text-secondary);
    line-height: 1.8;
  }

  .experience-section {
    padding: 0 0.75rem;
  }

  hr {
    opacity: 0.15;
    margin-left: auto;
    margin-right: auto;
    width: 70%;
  }

  .about-content strong {
    color: var(--color-heading);
    font-weight: 600;
  }

  .about-content em {
    color: var(--color-accent);
    font-style: normal;
    border-bottom: 1px dotted;
    padding-bottom: 1px;
  }

  @media (max-width: 768px) {
    .experience-section {
      padding: 0 0.5rem;
      margin-bottom: 3rem !important;
    }

    hr {
      margin-top: 3rem !important;
      margin-bottom: 3rem !important;
    }
  }
</style>
