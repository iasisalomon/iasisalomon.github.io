---
import projectsData from '../data/projects.json';
const { brands, projects } = projectsData;

const projectCountByBrand = brands.reduce((acc, brand) => {
  acc[brand.id] = projects.filter(p => p.brand === brand.id).length;
  return acc;
}, {} as Record<string, number>);
---

<section id="brands" class="py-6 bg-light">
  <div class="container">
    <h2 class="text-center mt-1 mb-4">Brands</h2>
    <div class="section-divider mb-5"></div>

    <div class="row g-4">
      {brands.map(brand => (
        <div id={`${brand.id}-brand`} class="col-lg-4">
          <div class={`brand-section h-100 p-4 p-lg-5 rounded-4 ${brand.gradientClass} text-white`}>
            <div class="text-center mb-4">
              <i class={`${brand.icon} display-3 mb-4 opacity-75`}></i>
              <h3 class="h2 mb-2">{brand.name}</h3>
              <p class="lead mb-3">{brand.description}</p>
              <span class="project-count-badge">
                {projectCountByBrand[brand.id]} project{projectCountByBrand[brand.id] !== 1 ? 's' : ''}
              </span>
              <div class="d-flex flex-wrap justify-content-center gap-2 mt-3 mb-4">
                {brand.tags.map(tag => (
                  <span class="badge bg-light text-dark border">{tag}</span>
                ))}
              </div>
            </div>
            <div class="d-flex flex-wrap justify-content-center gap-3">
              {brand.links.map(link => (
                <a href={link.url} class="btn btn-outline-light mb-2" target="_blank" rel="noopener noreferrer">
                  <i class={`${link.icon} me-2`}></i>{link.text}
                </a>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .project-count-badge {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.3em 0.9em;
    border-radius: 100px;
    background-color: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.25);
    letter-spacing: 0.3px;
  }
</style>
