---
import MainLayout from '../layouts/MainLayout.astro';
import { SITE_DESCRIPTION } from '../consts';
import Navbar from '../components/Navbar.astro';
import About from '../components/About.astro';
import Hero from '../components/Hero.astro';
import Expertise from '../components/Expertise.astro';
import SelectedWork from '../components/SelectedWork.astro';
import Projects from '../components/Projects.astro';
import Writing from '../components/Writing.astro';
import Testimonials from '../components/Testimonials.astro';
import CustomFooter from '../components/CustomFooter.astro';
import Discussion from '../components/Discussion.astro';
---

<MainLayout
	title="Iasi Salomon — Operations, Engineering & Live Production"
	description={SITE_DESCRIPTION}
>
	<Navbar />
	<Hero />
	<About />
	<Expertise />
	<SelectedWork />
	<Projects />
	<Testimonials />
	<Discussion />
	<Writing />
	<CustomFooter />
</MainLayout>
