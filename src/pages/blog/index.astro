---
import MainLayout from '../../layouts/MainLayout.astro';
import Navbar from '../../components/Navbar.astro';
import CustomFooter from '../../components/CustomFooter.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);

const categoryLabels: Record<string, string> = {
	tech: 'Tech',
	business: 'Business',
	other: 'Other',
};
---

<MainLayout title="Blog | Iasi Salomon">
	<Navbar />

	<section class="blog-section py-5 mt-5">
		<div class="container">
			<header class="blog-header">
				<h1 class="blog-title">Articles</h1>
				<p class="blog-description">Thoughts, ideas, and explorations</p>

				<div class="category-tabs mt-4">
					<button class="category-tab active" data-category="all">All</button>
					<button class="category-tab" data-category="tech">Tech</button>
					<button class="category-tab" data-category="business">Business</button>
					<button class="category-tab" data-category="other">Other</button>
				</div>
			</header>

			<div class="blog-grid" id="blogGrid">
				{posts.map((post) => (
					<article class="blog-card" data-category={post.data.category ?? 'other'}>
						<a href={`/blog/${post.id}/`} class="card-link">
							<div class="card-image">
								<img src={post.data.heroImage || '/images/blog/blog-placeholder-about.jpg'} alt={post.data.title} loading="lazy" />
							</div>
							<div class="card-content">
								<header class="card-header">
									<div class="card-meta">
										{post.data.pubDate && (
											<time datetime={post.data.pubDate.toISOString()} class="card-date">
												{post.data.pubDate.toLocaleDateString('en-us', {
													year: 'numeric',
													month: 'short',
													day: 'numeric',
												})}
											</time>
										)}
										{post.data.category && (
											<span class={`category-badge category-${post.data.category}`}>
												{categoryLabels[post.data.category]}
											</span>
										)}
									</div>
									<h2 class="card-title">{post.data.title}</h2>
								</header>
								<p class="card-excerpt">{post.data.description}</p>
								<footer class="card-footer">
									<span class="read-more">Read article →</span>
								</footer>
							</div>
						</a>
					</article>
				))}
			</div>

			<p id="noPostsMsg" class="text-center text-muted py-5" style="display:none">No posts in this category yet.</p>
		</div>
	</section>

	<CustomFooter />
</MainLayout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.category-tab');
  const cards = document.querySelectorAll<HTMLElement>('.blog-card');
  const noPostsMsg = document.getElementById('noPostsMsg')!;

  function applyFilter(category: string) {
    let visible = 0;
    cards.forEach(card => {
      const match = category === 'all' || card.dataset.category === category;
      card.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    noPostsMsg.style.display = visible === 0 ? '' : 'none';

    tabs.forEach(t => t.classList.toggle('active', t.dataset.category === category));

    const url = new URL(window.location.href);
    if (category === 'all') {
      url.searchParams.delete('category');
    } else {
      url.searchParams.set('category', category);
    }
    history.replaceState(null, '', url.toString());
  }

  // Init from URL on load
  const initialCategory = new URLSearchParams(window.location.search).get('category') ?? 'all';
  applyFilter(initialCategory);

  tabs.forEach(tab => {
    tab.addEventListener('click', () => applyFilter(tab.dataset.category!));
  });
</script>

<style>
	.blog-section {
		margin: 2rem auto 6rem;
	}

	.blog-header {
		margin-bottom: 3rem;
		text-align: center;
	}

	.blog-title {
		font-size: 2.5rem;
		font-weight: 700;
		margin-bottom: 0.5rem;
		letter-spacing: -0.02em;
		color: var(--color-heading);
	}

	.blog-description {
		font-size: 1.2rem;
		color: var(--color-text-muted);
		max-width: 600px;
		margin: 0 auto;
	}

	.category-tabs {
		display: flex;
		justify-content: center;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.category-tab {
		padding: 0.4em 1.1em;
		border-radius: var(--radius-pill);
		font-size: 0.9rem;
		font-weight: 500;
		color: var(--color-text-secondary);
		border: 1px solid var(--color-border-strong);
		background: none;
		cursor: pointer;
		transition: all 0.2s ease;
	}

	.category-tab:hover {
		border-color: var(--color-text-muted);
		color: var(--color-heading);
	}

	.category-tab.active {
		background-color: var(--color-accent);
		border-color: var(--color-accent);
		color: #fff;
	}

	.card-meta {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		margin-bottom: 0.7rem;
	}

	.category-badge {
		font-size: 0.75rem;
		font-weight: 600;
		padding: 0.2em 0.7em;
		border-radius: var(--radius-pill);
		text-transform: uppercase;
		letter-spacing: 0.4px;
	}

	.category-tech     { background: var(--badge-tech-bg); color: var(--badge-tech-text); }
	.category-business { background: var(--badge-business-bg); color: var(--badge-business-text); }
	.category-other    { background: var(--badge-other-bg); color: var(--badge-other-text); }

	.blog-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
		gap: 2.5rem;
	}

	.blog-card {
		border-radius: 10px;
		overflow: hidden;
		transition: all 0.3s ease;
		box-shadow: var(--shadow-card);
		background-color: var(--color-card);
		border: 1px solid var(--color-border);
		animation: fadeIn 0.5s ease forwards;
		opacity: 0;
	}

	.card-image {
		height: 200px;
		overflow: hidden;
	}

	.card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.5s ease;
	}

	.blog-card:hover .card-image img { transform: scale(1.05); }

	.card-content {
		padding: 1.8rem;
		display: flex;
		flex-direction: column;
	}

	@keyframes fadeIn {
		from { opacity: 0; transform: translateY(20px); }
		to   { opacity: 1; transform: translateY(0); }
	}

	.blog-card:hover {
		transform: translateY(-5px);
		box-shadow: var(--shadow-card-hover);
		border-color: var(--color-border-strong);
	}

	.card-link {
		display: block;
		text-decoration: none;
		color: inherit;
	}

	.card-header    { margin-bottom: 1rem; }

	.card-date {
		font-size: 0.85rem;
		color: var(--color-text-muted);
	}

	.card-title {
		font-size: 1.4rem;
		font-weight: 600;
		line-height: 1.3;
		margin: 0 0 0.5rem;
		color: var(--color-heading);
		transition: color 0.2s ease;
	}

	.blog-card:hover .card-title { color: var(--color-accent); }

	.card-excerpt {
		font-size: 1rem;
		line-height: 1.6;
		color: var(--color-text-secondary);
		margin-bottom: 1.5rem;
		flex-grow: 1;
	}

	.card-footer  { margin-top: auto; }

	.read-more {
		display: inline-block;
		font-size: 0.9rem;
		font-weight: 500;
		color: var(--color-accent);
		transition: transform 0.2s ease;
	}

	.blog-card:hover .read-more { transform: translateX(5px); }

	.blog-card:nth-child(1) { animation-delay: 0.1s; }
	.blog-card:nth-child(2) { animation-delay: 0.2s; }
	.blog-card:nth-child(3) { animation-delay: 0.3s; }

	@media (max-width: 768px) {
		.blog-grid        { grid-template-columns: 1fr; gap: 1.5rem; }
		.blog-title       { font-size: 2rem; }
		.blog-description { font-size: 1.1rem; }
		.card-content     { padding: 1.5rem; }
		.card-title       { font-size: 1.3rem; }
	}
</style>
